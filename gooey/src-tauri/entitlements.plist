<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow outbound network connections (Tauri WebView → Flask sidecar) -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Allow inbound connections (Flask sidecar binds port 5254) -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Required: sidecar loads Homebrew-signed Python.framework (different Team ID than ad-hoc binary) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
