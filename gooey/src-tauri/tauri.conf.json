{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gooey",
  "version": "0.2.0",
  "identifier": "com.theatergwd.gooey",
  "build": {
    "frontendDist": ".",
    "devUrl": "http://localhost:5001"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "annieData — Gooey",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "visible": true,
        "url": "loading.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/gooey-server"
    ]
  }
}
