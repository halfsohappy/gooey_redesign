{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "annieData",
  "version": "0.2.0",
  "identifier": "com.theatergwd.anniedata",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:5254"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "annieData",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "visible": true,
        "url": "loading.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/gooey-server"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
